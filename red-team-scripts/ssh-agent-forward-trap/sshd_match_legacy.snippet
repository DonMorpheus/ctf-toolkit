# Add to sshd_config (lab: port 2221 user legacy). Restart sshd after install.
AllowTcpForwarding no
AllowAgentForwarding yes
PermitTunnel no

Match User legacy LocalAddress * LocalPort 2221
    ForceCommand /usr/local/bin/require_agent_forward.sh
    AllowTcpForwarding no
    AllowAgentForwarding yes
    PasswordAuthentication no
    PubkeyAuthentication yes