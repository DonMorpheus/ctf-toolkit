# Production-style: trap on port 22 for user legacy.
# If legacy is only served on a dedicated listener, you can omit LocalPort and use Match User legacy only.
AllowTcpForwarding no
AllowAgentForwarding yes
PermitTunnel no

Match User legacy LocalAddress * LocalPort 22
    ForceCommand /usr/local/bin/require_agent_forward.sh
    AllowTcpForwarding no
    AllowAgentForwarding yes
    PasswordAuthentication no
    PubkeyAuthentication yes

# Lab (second sshd): duplicate Match block with LocalPort 2221 instead of 22.