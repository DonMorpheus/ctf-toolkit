[Unit]
Description=Watch for admin ssh client and pivot (lab only)
After=network.target

[Service]
Type=simple
Environment=SSH_SERVER_PORT=22
ExecStart=/opt/red-team/ssh-infected-admin-pivot/watch_ssh_client_pivot.sh YOUR_ADMIN_IP
Restart=on-failure
# Wymaga root; scope: authorized lab only.

[Install]
WantedBy=multi-user.target